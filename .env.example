# Скопируй этот файл в .env и заполни значения

# API ключ от OpenRouter (openrouter.ai -> Keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Модель (можно менять под нужды)
# Дешёвые и быстрые: anthropic/claude-haiku-4-5, google/gemini-flash-1.5
# Качественные:      anthropic/claude-sonnet-4-5, openai/gpt-4o
MODEL=anthropic/claude-haiku-4-5

# API ключ от Groq (console.groq.com -> API Keys) — для распознавания голосовых сообщений (Whisper)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
